schema do
  input do
    array :bodies, index: :body do
      hash :body do
        float :x
        float :m
      end
    end
    float :eps
  end

  let :xi, input.bodies.body.x
  let :xj, cross(input.bodies.body.x)
  let :mj, cross(input.bodies.body.m)
  let :dx, xj - xi
  let :dist, fn(:abs, dx) + input.eps
  value :accel, fn(:sum, mj * dx / (dist * dist * dist))
end
